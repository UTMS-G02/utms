@startuml uc-15
autonumber
skinparam maxMessageSize 150
skinparam ParticipantPadding 20
skinparam BoxPadding 10

actor Student

box "Presentation Layer" #LightCyan
    participant "StudentDashboardUI" as UI
    participant "NotificationRestController" as RestController
end box

box "Business Logic Layer" #LightYellow
    participant "NotificationService" as NotifSvc
end box

box "Data Access Layer" #LightGreen
    participant "NotificationRepository" as NotifDB
end box

box "Database" #LightPink
    participant "Database" as DB
end box

== 1. Viewing Notifications (Bildirimleri Görüntüleme) ==
Student -> UI: clickNotificationBox()
activate UI

UI -> RestController: GET /api/notifications/{studentId}
activate RestController

RestController -> NotifSvc: getStudentNotifications(studentId)
activate NotifSvc

NotifSvc -> NotifDB: findNotificationsByStudentId(studentId)
activate NotifDB

NotifDB -> DB: read(studentId)
activate DB
DB --> NotifDB: ResultSet
deactivate DB

NotifDB --> NotifSvc: List<Notification>: notifications
deactivate NotifDB

NotifSvc --> RestController: List<Notification>: notifications
deactivate NotifSvc

RestController --> UI: HTTP 200 OK: notifications
deactivate RestController

alt No Notifications Found
    UI -> UI: renderEmptyState()
    UI --> Student: Information Message ("Yeni bildiriminiz bulunmamaktadır.")
else Notifications Found
    UI -> UI: separateReadAndUnread(notifications)
    note right: UI groups notifications into "Unread" (highlighted) and "Read" sections based on the 'isRead' property.
    
    UI -> UI: renderNotificationList()
    UI --> Student: Display Notifications Dropdown / Modal
end

== 2. Marking Notification as Read (Okundu Olarak İşaretleme) ==
opt Student clicks an unread notification
    Student -> UI: clickUnreadNotification(notificationId)
    
    UI -> RestController: PATCH /api/notifications/{notificationId}/read
    activate RestController
    
    RestController -> NotifSvc: markAsRead(notificationId)
    activate NotifSvc
    
    NotifSvc -> NotifDB: updateReadStatus(notificationId, "Read")
    activate NotifDB
    
    NotifDB -> DB: update(notificationId)
    activate DB
    DB --> NotifDB: success
    deactivate DB
    
    NotifDB --> NotifSvc: success
    deactivate NotifDB
    
    NotifSvc --> RestController: void
    deactivate NotifSvc
    
    RestController --> UI: HTTP 200 OK
    deactivate RestController
    
    UI -> UI: updateUIIconToRead(notificationId)
    UI --> Student: Display Notification Details
end

== 3. Deleting a Notification (Bildirim Silme) ==
opt Student clicks delete icon on a notification
    Student -> UI: clickDeleteNotification(notificationId)
    
    UI -> RestController: DELETE /api/notifications/{notificationId}
    activate RestController
    
    RestController -> NotifSvc: deleteNotification(notificationId)
    activate NotifSvc
    
    NotifSvc -> NotifDB: deleteNotificationById(notificationId)
    activate NotifDB
    
    NotifDB -> DB: delete(notificationId)
    activate DB
    DB --> NotifDB: success
    deactivate DB
    
    NotifDB --> NotifSvc: success
    deactivate NotifDB
    
    NotifSvc --> RestController: void
    deactivate NotifSvc
    
    RestController --> UI: HTTP 204 No Content
    deactivate RestController
    
    UI -> UI: removeNotificationFromView(notificationId)
    UI --> Student: Action Confirmation ("Bildirim silindi.")
end

deactivate UI

@enduml