@startuml uc-6
autonumber
skinparam maxMessageSize 150
skinparam ParticipantPadding 20
skinparam BoxPadding 10

actor "ÖİDB Staff" as Staff

box "Presentation Layer" #LightCyan
    participant "OidbDashboardUI" as UI
    participant "OidbRestFinalizationSvc" as RestFinalizationSvc
end box

box "Business Logic Layer" #LightYellow
    participant "FinalizationService" as FinalizationSvc
    participant "EmailNotificationManager" as EmailManager
end box

box "Data Access Layer" #LightGreen
    participant "BoardDecisionRepository" as DecisionDB
    participant "TransferApplicationRepository" as AppDB
    participant "NotificationRepository" as LogDB
end box

box "Database" #LightPink
    participant "Database" as DB
end box

== Retrieve & Review Decisions ==

Staff -> UI: selectApplicationCycle(cycleId)
activate UI

UI -> RestFinalizationSvc: GET /api/oidb/cycles/{cycleId}/decisions
activate RestFinalizationSvc

RestFinalizationSvc -> FinalizationSvc: fetchFinalDecisions(cycleId)
activate FinalizationSvc

FinalizationSvc -> DecisionDB: findByCycleId(cycleId)
activate DecisionDB
DecisionDB -> DB: read(cycleId)
activate DB

alt Invalid or Missing Faculty Data
    DB --> DecisionDB: Exception
    deactivate DB
    DecisionDB --> FinalizationSvc: DataCorruptedException
    deactivate DecisionDB
    FinalizationSvc --> RestFinalizationSvc: DataCorruptedException
    RestFinalizationSvc --> UI: HTTP 500: Missing Data Error
    UI --> Staff: Error("Eksik veri: Lütfen fakülte kararlarını doğrulayın")
else Valid Data
    DB --> DecisionDB: List<BoardDecision>
    deactivate DB
    DecisionDB --> FinalizationSvc: List<BoardDecision>
    deactivate DecisionDB
    FinalizationSvc --> RestFinalizationSvc: List<BoardDecision>: decisions
    RestFinalizationSvc --> UI: HTTP 200: decisions
    UI --> Staff: Decision Data
end

deactivate FinalizationSvc
deactivate RestFinalizationSvc
deactivate UI

== Publish & Notify ==

Staff -> UI: clickPublishResults()
activate UI

UI -> RestFinalizationSvc: POST /api/oidb/cycles/{cycleId}/publish
activate RestFinalizationSvc

RestFinalizationSvc -> FinalizationSvc: publishResults(cycleId)
activate FinalizationSvc

FinalizationSvc -> AppDB: updateApplicationStatusByCycleId(cycleId, "Finalized")
activate AppDB
AppDB -> DB: persist(applications)
activate DB
DB --> AppDB: void
deactivate DB
AppDB --> FinalizationSvc: void
deactivate AppDB

FinalizationSvc -> FinalizationSvc: triggerNotifications(cycleId)

FinalizationSvc -> EmailManager: sendStatusUpdates(cycleId)
activate EmailManager

alt Notification Failure
    EmailManager --> FinalizationSvc: EmailDeliveryException

    FinalizationSvc -> LogDB: save(new Notification(cycleId, status="Failed"))
    activate LogDB
    LogDB -> DB: persist(notification)
    activate DB
    DB --> LogDB: Notification
    deactivate DB
    LogDB --> FinalizationSvc: Notification
    deactivate LogDB

    FinalizationSvc --> RestFinalizationSvc: PartialSuccessException
    RestFinalizationSvc --> UI: HTTP 207: Partial Success
    UI --> Staff: Warning("Sonuçlar yayınlandı ancak bazı bildirimler başarısız oldu.")
else Notification Success
    EmailManager --> FinalizationSvc: void
    deactivate EmailManager

    FinalizationSvc -> LogDB: save(new Notification(cycleId, status="Sent"))
    activate LogDB
    LogDB -> DB: persist(notification)
    activate DB
    DB --> LogDB: Notification
    deactivate DB
    LogDB --> FinalizationSvc: Notification
    deactivate LogDB

    FinalizationSvc --> RestFinalizationSvc: void
    RestFinalizationSvc --> UI: HTTP 200 OK
    UI --> Staff: Confirmation("Sonuçlar başarıyla yayınlandı ve bildirimler gönderildi.")
end

deactivate FinalizationSvc
deactivate RestFinalizationSvc
deactivate UI

@enduml
