@startuml uc-9
autonumber
skinparam maxMessageSize 150
skinparam ParticipantPadding 20
skinparam BoxPadding 10

actor "Administrative Staff (ÖİDB)" as Admin

box "Presentation Layer" #LightCyan
    participant "FinalizationUI" as UI
    participant "FinalizationRestController" as RestController
end box

box "Business Logic Layer" #LightYellow
    participant "FinalizationService" as FinalService
    participant "EmailNotificationService" as EmailService
end box

box "Data Access Layer" #LightGreen
    participant "TransferApplicationRepository" as AppRepo
    participant "NotificationRepository" as LogDB
end box

box "Database" #LightPink
    participant "Database" as DB
end box

box "External Services" #LightGray
    participant "Email API" as ExternalEmail
end box

== Review & Finalize Decision ==

Admin -> UI: viewEvaluatedApplications()
activate UI

UI -> RestController: GET /api/admin/finalization/pending
activate RestController

RestController -> FinalService: getPendingFinalizations()
activate FinalService

FinalService -> AppRepo: findAllByStatus("EVALUATED")
activate AppRepo
AppRepo -> DB: SELECT * FROM applications WHERE status = 'EVALUATED'
activate DB
DB --> AppRepo: ResultSet
deactivate DB
AppRepo --> FinalService: List<Application>
deactivate AppRepo

FinalService --> RestController: List<FinalizationDTO>
deactivate FinalService

RestController --> UI: HTTP 200: Data
deactivate RestController
UI --> Admin: Show Evaluated Applications
deactivate UI

== Final Decision & Notification ==

Admin -> UI: confirmFinalStatus(appId, "Accepted")
activate UI

UI -> RestController: PATCH /api/admin/applications/{id}/finalize
activate RestController

RestController -> FinalService: finalizeAndNotify(appId, "Accepted")
activate FinalService

FinalService -> AppRepo: updateFinalStatus(appId, "Accepted")
activate AppRepo
AppRepo -> DB: UPDATE applications SET final_status = 'Accepted', status = 'FINALIZED'
activate DB
DB --> AppRepo: int: rowsAffected
deactivate DB
AppRepo --> FinalService: boolean: true
deactivate AppRepo

== Notification Flow (Same as UC-6) ==

FinalService -> EmailService: sendStatusUpdate(studentEmail, "Accepted")
activate EmailService

EmailService -> ExternalEmail: send(studentEmail, message)
activate ExternalEmail

alt  Notification Failure 
    ExternalEmail --> EmailService: Exception / HTTP 500
    EmailService -> LogDB: save(Notification(status="Failed"))
    EmailService --> FinalService: Exception: DeliveryFailure
else Notification Success
    ExternalEmail --> EmailService: HTTP 200 OK
    deactivate ExternalEmail
    EmailService -> LogDB: save(Notification(status="Sent"))
    EmailService --> FinalService: boolean: true
end
deactivate EmailService

FinalService --> RestController: boolean: true
deactivate FinalService

RestController --> UI: HTTP 200 OK
deactivate RestController

UI --> Admin: SuccessMessage("Başvuru başarıyla sonuçlandırıldı.")
deactivate UI

@enduml