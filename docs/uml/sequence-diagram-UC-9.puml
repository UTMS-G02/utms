@startuml scenario-9-intibak
autonumber
skinparam maxMessageSize 150
skinparam ParticipantPadding 20
skinparam BoxPadding 10

actor "Academic Staff (YGK)" as YGK

box "Presentation Layer" #LightCyan
    participant "IntibakUI" as UI
    participant "IntibakRestController" as RestController
end box

box "Business Logic Layer" #LightYellow
    participant "IntibakManager" as Manager
end box

box "Data Access Layer" #LightGreen
    participant "IntibakRepository" as Repo
end box

box "Database" #LightPink
    participant "Database" as DB
end box

== Row Management (Dynamic Table) ==

YGK -> UI: clickAddCourse()
activate UI
UI --> YGK: appendBlankRow()
note right of UI: UI handles dynamic row\ncreation locally
deactivate UI

loop [For each course in Student Transcript]

    YGK -> UI: enterMappingData(sourceCourse,\ntargetCourse, credits)
    activate UI

    YGK -> UI: selectEquivalencyStatus(status)
    note right of UI: Options: Tam denklik, Kısmi Denklik,\nDenk değil

    UI -> RestController: POST\n/api/intibak/validate-credits
    activate RestController

    RestController -> Manager: validateNumericCredits(credits)
    activate Manager

    alt [Valid Numeric Entry]
        Manager --> RestController: validationSuccess
        RestController --> UI: HTTP 200 (Success)

    else [Non-numeric Entry (EX-1)]
        Manager --> RestController: InvalidCreditException
        deactivate Manager
        RestController --> UI: HTTP 400 (Highlight Field Red)\n(cite: 854, 907)
        deactivate RestController
    end

    deactivate UI

end

alt [Alternative: Delete  Row ]
    YGK -> UI: clickDeleteIcon(rowId)
    activate UI
    UI --> YGK: removeRowFromDisplay()
    deactivate UI
end

== Finalization of Table ==

YGK -> UI: clickSaveAndFinalize()
activate UI

UI -> RestController: POST\n/api/intibak/{applicationId}/save
activate RestController

RestController -> Manager: saveTable(mappingList)
activate Manager

Manager -> Repo: saveAll(mappings)
activate Repo

Repo -> DB: INSERT/UPDATE\nINTIBAK_RECORD
activate DB
DB --> Repo: batchSuccess
deactivate DB

Repo --> Manager: true
deactivate Repo

Manager --> RestController: tableSaved
deactivate Manager

RestController --> UI: HTTP 200 OK
deactivate RestController

UI --> YGK: Confirmation("Intibak\ntablosu kaydedildi!")
deactivate UI

@enduml