@startuml UTMS_User_Auth_Design

title UTMS — User & Authentication Design

skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam packageStyle rectangle
skinparam class {
    BackgroundColor White
    BorderColor #2C3E50
    ArrowColor #2C3E50
}
skinparam package {
    BorderColor #5D6D7E
}

' =============================================
' BUSINESS LOGIC LAYER
' =============================================

package "Business Logic Layer" #FEF9E7 {

    package "Auth & Registration" #FDEBD0 {
        class AuthenticationService {
            +verifyCredentials(email : String, password : String)
            +generateOTP() : String
            +verifyOTP(userId : Integer, code : String) : Boolean
            +lockAccount(userId : Integer)
            +initiatePasswordReset(email : String)
            +verifyResetToken(token : String)
            +updatePassword(token : String, newPassword : String, confirmPassword : String)
            +validateSecurityPolicies(newPassword : String, confirmPassword : String)
            +hashPassword(password : String) : String
        }
        class RegistrationController {
            +validateEmailFormat(email : String)
            +checkEmailExists(email : String)
            +validatePasswordStrength(password : String)
            +hashPassword(password : String) : String
            +generateActivationLink() : String
            +verifyActivationLink(link : String)
        }
        class ProfileController {
            +validatePhoneNumber(phone : String)
            +verifyCurrentPassword(password : String)
            +hashNewPassword(newPassword : String) : String
        }
        class EmailNotificationManager {
            +sendStatusUpdate(email : String, message : String)
        }
    }
}

' =============================================
' DATA ACCESS LAYER
' =============================================

package "Data Access Layer" #EBF5FB {

    package "User Domain" #D6EAF8 {
        abstract class User {
            -userId : Integer
            -email : String
            -passwordHash : String
            -lastLoginDate : LocalDate
            -isActive : Boolean
        }
        class Student {
            -tckn : String
            -firstName : String
            -middleName : String
            -lastName : String
            -phoneNumber : String
            -dateOfBirth : LocalDate
            -kvkkAcceptedAt : LocalDate
            -gpa : Float
            -currentUniversity : String
            -currentDepartment : String
        }
        abstract class Staff {
            -title : String
        }
        class OidbStaff
        class YdyoStaff
        class YgkMember {
            -departmentId : Integer
        }
        class DeanOfficeStaff {
            -departmentId : Integer
        }
        class FacultyBoardMember {
            -departmentId : Integer
        }

        interface UserRepository {
            +findByEmail(email : String) : Optional<User>
            +findById(userId : Integer) : Optional<User>
            +save(user : User) : User
        }
    }

    package "Authentication" #D6EAF8 {
        class AuthToken {
            -tokenId : String
            -expiryDate : LocalDateTime
            -isValid : Boolean
        }
        class OTPRecord {
            -otpCode : String
            -failedAttempts : Integer
            -expiryTime : LocalDateTime
        }

        interface OTPRecordRepository {
            +findByUserId(userId : Integer) : OTPRecord
            +save(otp : OTPRecord) : OTPRecord
            +delete(otp : OTPRecord)
        }
        interface AuthTokenRepository {
            +findById(tokenId : String) : Optional<AuthToken>
            +save(token : AuthToken) : AuthToken
            +delete(token : AuthToken)
        }
    }
}

' =============================================
' INHERITANCE
' =============================================

User <|-- Student
User <|-- Staff
Staff <|-- OidbStaff
Staff <|-- YdyoStaff
Staff <|-- YgkMember
Staff <|-- DeanOfficeStaff
Staff <|-- FacultyBoardMember

' =============================================
' DOMAIN ASSOCIATIONS
' =============================================

User "1" -- "0..*" AuthToken : has >
User "1" -- "0..1" OTPRecord : has >

' =============================================
' BUSINESS LOGIC -> DATA ACCESS DEPENDENCIES
' =============================================

AuthenticationService ..> UserRepository : uses
AuthenticationService ..> OTPRecordRepository : uses
AuthenticationService ..> AuthTokenRepository : uses
RegistrationController ..> UserRepository : uses
ProfileController ..> UserRepository : uses

@enduml
