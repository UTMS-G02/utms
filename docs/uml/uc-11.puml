@startuml uc-11
autonumber
skinparam maxMessageSize 150
skinparam ParticipantPadding 20
skinparam BoxPadding 10

actor "Faculty Board Member" as Board

box "Presentation Layer" #LightCyan
participant "FacultyBoardUI" as UI
end box

box "Business Logic Layer" #LightYellow
participant "FacultyBoardController" as Controller
end box

box "Data Access Layer" #LightGreen
participant "TransferApplication" as AppDB
participant "EvaluationReport" as EvalDB
participant "BoardDecision" as DecisionDB
end box

box "Database" #LightPink
participant "PostgreSQL" as DB
end box

== Application Review ==
Board -> UI: selectApplicantReview(applicationId)
activate UI

UI -> Controller: fetchApplicationDetails(applicationId)
activate Controller

Controller -> AppDB: findById(applicationId)
activate AppDB
AppDB -> DB: SELECT * FROM TransferApplications WHERE id = ?
activate DB
DB --> AppDB: ResultSet
deactivate DB
AppDB --> Controller: TransferApplication: appData
deactivate AppDB

Controller -> EvalDB: getEvaluationWithIntibak(applicationId)
activate EvalDB
EvalDB -> DB: SELECT * FROM EvaluationReports JOIN IntibakTables ... WHERE applicationId = ?
activate DB
DB --> EvalDB: ResultSet
deactivate DB
EvalDB --> Controller: EvaluationReport: evalData
deactivate EvalDB

Controller --> UI: ConsolidatedData: report
UI --> Board: displayConsolidatedReport(report)
deactivate Controller

== Decision Making ==
alt Application Approved (Normal Flow)
    Board -> UI: clickApprove()
    UI -> Controller: recordFinalDecision(applicationId, "Approved", null)
    activate Controller
    
else Application Rejected (Alternative Flow)
    Board -> UI: clickReject()
    UI --> Board: showRejectionCodeDropdown()
    
    Board -> UI: selectRejectionCode(rejectionCode)
    Board -> UI: enterCommentsAndConfirm(comments)
    UI -> Controller: recordFinalDecision(applicationId, "Rejected", rejectionCode)
end

== Recording the Decision ==
Controller -> DecisionDB: save(BoardDecision(decisionType, rejectionCode, timestamp))
activate DecisionDB
DecisionDB -> DB: INSERT INTO BoardDecisions (decisionType, rejectionCode, timestamp, applicationId) VALUES (?, ?, ?, ?)
activate DB
DB --> DecisionDB: int: decisionId
deactivate DB
DecisionDB --> Controller: boolean: true
deactivate DecisionDB

Controller -> AppDB: updateFinalDecision(applicationId, decisionType, decisionId)
activate AppDB
AppDB -> DB: UPDATE TransferApplications SET finalDecision = ?, boardDecisionId = ? WHERE id = ?
activate DB
DB --> AppDB: int: rowsAffected
deactivate DB
AppDB --> Controller: boolean: true
deactivate AppDB

Controller --> UI: boolean: true
deactivate Controller

UI --> Board: showConfirmationMessage("Karar başarıyla kaydedildi") & returnToApplicationList()
deactivate UI

@enduml