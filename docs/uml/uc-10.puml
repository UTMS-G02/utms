DB --> AppDB: List<TransferApplication>
deactivate DB
AppDB --> BL: List<TransferApplication>
deactivate AppDB

BL --> RestController: void
deactivate BL

RestController --> UI: HTTP 200 OK
deactivate RestController

UI --> Staff: Confirmation('Başvurular Fakülte Kurulu'na iletildi.')
deactivate UI

== Scenario C: Finalizing to OİDB ==
note over UI, DB: Tab: 'Fakülte Kurulundan Gelen'

Staff -> UI: clickTab('Fakülte Kurulundan Gelen')
activate UI

UI -> RestController: GET /api/dean/applications?tab=from-faculty
activate RestController

RestController -> BL: fetchApplicationsByStatus('Değerlendirme Onaylandı')
activate BL

BL -> AppDB: findByApplicationStatus('Değerlendirme Onaylandı')
activate AppDB
AppDB -> DB: read(status)
activate DB
DB --> AppDB: List<TransferApplication>
deactivate DB
AppDB --> BL: List<TransferApplication>
deactivate AppDB

BL --> RestController: List<TransferApplication>
deactivate BL

RestController --> UI: HTTP 200: applications
deactivate RestController

UI --> Staff: Application List with Board Decisions
deactivate UI

Staff -> UI: selectApplications(applicationIds)
activate UI
Staff -> UI: clickReturnToOidb()

UI -> RestController: PATCH /api/dean/applications/return-to-oidb (applicationIds)
activate RestController

RestController -> BL: returnToOidb(applicationIds)
activate BL

BL -> AppDB: findAllById(applicationIds)
activate AppDB
AppDB -> DB: read(applicationIds)
activate DB
DB --> AppDB: List<TransferApplication>
deactivate DB
AppDB --> BL: List<TransferApplication>
deactivate AppDB

BL -> BL: applications.forEach(a -> a.setApplicationStatus('Finalized'))

BL -> AppDB: saveAll(applications)
activate AppDB
AppDB -> DB: persist(applications)
activate DB
DB --> AppDB: List<TransferApplication>
deactivate DB
AppDB --> BL: List<TransferApplication>
deactivate AppDB

BL --> RestController: void
deactivate BL

RestController --> UI: HTTP 200 OK
deactivate RestController

UI --> Staff: Confirmation('Başvurular OİDB'ye iletildi.')
deactivate UI

@enduml
