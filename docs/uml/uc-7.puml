@startuml uc-7
autonumber
skinparam maxMessageSize 150
skinparam ParticipantPadding 20
skinparam BoxPadding 10

actor "YDYO Staff" as Staff

box "Presentation Layer" #LightCyan
    participant "YdyoDashboardUI" as UI
    participant "YdyoRestController" as RestController
end box

box "Business Logic Layer" #LightYellow
    participant "ProficiencyEvaluationService" as BL
end box

box "Data Access Layer" #LightGreen
    participant "TransferApplicationRepository" as AppDB
    participant "ProficiencyRecordRepository" as ProfDB
end box

box "Database" #LightPink
    participant "Database" as DB
end box

== Phase 1: View Student List ==

Staff -> UI: navigateToDashboard()
activate UI

UI -> RestController: GET /api/ydyo/applications
activate RestController

RestController -> BL: fetchApplicationList()
activate BL

BL -> AppDB: findByApplicationStatus('Forwarded to YDYO')
activate AppDB
AppDB -> DB: read(status)
activate DB
DB --> AppDB: List<TransferApplication>
deactivate DB
AppDB --> BL: List<TransferApplication>
deactivate AppDB

BL --> RestController: List<TransferApplication>
deactivate BL

RestController --> UI: HTTP 200: applications
deactivate RestController

UI --> Staff: Student List
deactivate UI

== Phase 2: Document Evaluation ==

Staff -> UI: selectStudent(applicationId)
activate UI

UI -> RestController: GET /api/ydyo/applications/{applicationId}
activate RestController

RestController -> BL: fetchApplicationDetails(applicationId)
activate BL

BL -> ProfDB: findByApplicationId(applicationId)
activate ProfDB
ProfDB -> DB: read(applicationId)
activate DB
DB --> ProfDB: EnglishProficiencyRecord
deactivate DB
ProfDB --> BL: EnglishProficiencyRecord
deactivate ProfDB

BL --> RestController: EnglishProficiencyRecord
deactivate BL

RestController --> UI: HTTP 200: proficiencyRecord
deactivate RestController

UI --> Staff: Student Details & Documents
deactivate UI

alt Document Approved (Exempt Path)

    Staff -> UI: setDocumentApprovalStatus('Onaylandi')
    Staff -> UI: enterExplanation(explanation)
    Staff -> UI: clickSave()
    activate UI

    UI -> RestController: PATCH /api/ydyo/applications/{applicationId}/proficiency\n(approvalStatus=Onaylandi, explanation)
    activate RestController

    RestController -> BL: approveDocument(applicationId, explanation)
    activate BL

    BL -> BL: calculateExemptionStatus('Onaylandi')\n-> examResult = 'Sinav Gerekli Degil'\n-> exemptionStatus = 'Muaf'

    BL -> ProfDB: findByApplicationId(applicationId)
    activate ProfDB
    ProfDB -> DB: read(applicationId)
    activate DB
    DB --> ProfDB: EnglishProficiencyRecord
    deactivate DB
    ProfDB --> BL: EnglishProficiencyRecord
    deactivate ProfDB

    BL -> BL: record.setDocumentApprovalStatus('Onaylandi')
    BL -> BL: record.setExamResult('Sinav Gerekli Degil')
    BL -> BL: record.setExemptionStatus('Muaf')
    BL -> BL: record.setExplanationNote(explanation)

    BL -> ProfDB: save(record)
    activate ProfDB
    ProfDB -> DB: persist(record)
    activate DB
    DB --> ProfDB: EnglishProficiencyRecord
    deactivate DB
    ProfDB --> BL: EnglishProficiencyRecord
    deactivate ProfDB

    BL --> RestController: void
    deactivate BL

    RestController --> UI: HTTP 200 OK
    deactivate RestController

    UI --> Staff: Record Saved & Return to List
    deactivate UI

else Document Rejected (Exam Path)

    Staff -> UI: setDocumentApprovalStatus('Onaylanmadi')
    Staff -> UI: enterExplanation(explanation)
    Staff -> UI: clickSave()
    activate UI

    UI -> RestController: PATCH /api/ydyo/applications/{applicationId}/proficiency\n(approvalStatus=Onaylanmadi, explanation)
    activate RestController

    RestController -> BL: rejectDocument(applicationId, explanation)
    activate BL

    alt Missing Explanation (8-EX)
        BL --> RestController: MissingExplanationException
        RestController --> UI: HTTP 400: Explanation Required
        UI --> Staff: Error('Lutfen aciklama giriniz.')
    else Explanation Provided
        BL -> BL: calculateExemptionStatus('Onaylanmadi')\n-> examResult = 'Sinav Sonucu Bekleniyor'\n-> exemptionStatus = 'Beklemede'

        BL -> ProfDB: findByApplicationId(applicationId)
        activate ProfDB
        ProfDB -> DB: read(applicationId)
        activate DB
        DB --> ProfDB: EnglishProficiencyRecord
        deactivate DB
        ProfDB --> BL: EnglishProficiencyRecord
        deactivate ProfDB

        BL -> BL: record.setDocumentApprovalStatus('Onaylanmadi')
        BL -> BL: record.setExamResult('Sinav Sonucu Bekleniyor')
        BL -> BL: record.setExemptionStatus('Beklemede')
        BL -> BL: record.setExplanationNote(explanation)

        BL -> ProfDB: save(record)
        activate ProfDB
        ProfDB -> DB: persist(record)
        activate DB
        DB --> ProfDB: EnglishProficiencyRecord
        deactivate DB
        ProfDB --> BL: EnglishProficiencyRecord
        deactivate ProfDB

        BL --> RestController: void
        deactivate BL

        RestController --> UI: HTTP 200 OK
        deactivate RestController

        UI --> Staff: Record Saved & Return to List
        deactivate UI
    end

    == Phase 2b: Exam Result Entry (after offline exam) ==

    Staff -> UI: selectStudent(applicationId)
    activate UI

    UI -> RestController: GET /api/ydyo/applications/{applicationId}
    activate RestController
    RestController -> BL: fetchApplicationDetails(applicationId)
    activate BL
    BL -> ProfDB: findByApplicationId(applicationId)
    activate ProfDB
    ProfDB -> DB: read(applicationId)
    activate DB
    DB --> ProfDB: EnglishProficiencyRecord
    deactivate DB
    ProfDB --> BL: EnglishProficiencyRecord
    deactivate ProfDB
    BL --> RestController: EnglishProficiencyRecord
    deactivate BL
    RestController --> UI: HTTP 200: proficiencyRecord
    deactivate RestController
    UI --> Staff: Student Details
    deactivate UI

    Staff -> UI: setExamResult(examResult)
    Staff -> UI: enterExplanation(explanation)
    Staff -> UI: clickSave()
    activate UI

    UI -> RestController: PATCH /api/ydyo/applications/{applicationId}/exam-result\n(examResult, explanation)
    activate RestController

    RestController -> BL: updateExamResult(applicationId, examResult, explanation)
    activate BL

    BL -> BL: calculateExemptionStatus(examResult)\n-> 'Sinav Basarili' => exemptionStatus = 'Muaf'\n-> 'Sinav Basarisiz' => exemptionStatus = 'Muaf Degil'

    BL -> ProfDB: findByApplicationId(applicationId)
    activate ProfDB
    ProfDB -> DB: read(applicationId)
    activate DB
    DB --> ProfDB: EnglishProficiencyRecord
    deactivate DB
    ProfDB --> BL: EnglishProficiencyRecord
    deactivate ProfDB

    BL -> BL: record.setExamResult(examResult)
    BL -> BL: record.setExemptionStatus(exemptionStatus)
    BL -> BL: record.setExplanationNote(explanation)

    BL -> ProfDB: save(record)
    activate ProfDB
    ProfDB -> DB: persist(record)
    activate DB
    DB --> ProfDB: EnglishProficiencyRecord
    deactivate DB
    ProfDB --> BL: EnglishProficiencyRecord
    deactivate ProfDB

    BL --> RestController: void
    deactivate BL

    RestController --> UI: HTTP 200 OK
    deactivate RestController

    UI --> Staff: Record Saved & Return to List
    deactivate UI

end

== Phase 3: Forward List to OİDB ==

Staff -> UI: clickForwardToOidb()
activate UI

UI -> RestController: POST /api/ydyo/applications/forward-to-oidb
activate RestController

RestController -> BL: forwardListToOidb()
activate BL

BL -> ProfDB: findByExemptionStatus('Beklemede')
activate ProfDB
ProfDB -> DB: read(status)
activate DB
DB --> ProfDB: List<EnglishProficiencyRecord>
deactivate DB
ProfDB --> BL: List<EnglishProficiencyRecord>
deactivate ProfDB

alt Incomplete Records Exist (12-EX)
    BL --> RestController: IncompleteRecordsException
    RestController --> UI: HTTP 400: Incomplete Records
    UI --> Staff: Error('Tum ogrenci kayitlari tamamlanmadan liste iletilemez.')
else All Records Finalized
    BL -> AppDB: findByApplicationStatus('Forwarded to YDYO')
    activate AppDB
    AppDB -> DB: read(status)
    activate DB
    DB --> AppDB: List<TransferApplication>
    deactivate DB
    AppDB --> BL: List<TransferApplication>
    deactivate AppDB

    BL -> BL: applications.forEach(a -> a.setApplicationStatus('YDYO Completed'))

    BL -> AppDB: saveAll(applications)
    activate AppDB
    AppDB -> DB: persist(applications)
    activate DB
    DB --> AppDB: List<TransferApplication>
    deactivate DB
    AppDB --> BL: List<TransferApplication>
    deactivate AppDB

    BL --> RestController: void
    deactivate BL

    RestController --> UI: HTTP 200 OK
    deactivate RestController

    UI --> Staff: Confirmation('Liste basariyla OİDB'ye iletildi.')
    deactivate UI
end

@enduml
