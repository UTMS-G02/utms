    namespace BusinessLogicLayer {
        class IExternalVerificationService {
            <<interface>>
            +verifyIdentity(String tckn) Boolean
            +fetchAcademicData(String tckn) ExternalDataResponse
        }
        class YoksisVerificationService
        class OsymVerificationService
        class EDevletVerificationService

        class ITransferApplicationService {
            <<interface>>
            +submitApplication(TransferApplication app)
            +updateStatus(Integer appId, String status)
        }
        class TransferApplicationManager

        class IEvaluationService {
            <<interface>>
            +calculateCompositeScore(Float gpa, Integer yks) Float
            +generateDraftRanking() Student[]
        }
        class YgkEvaluationManager

        class INotificationService {
            <<interface>>
            +sendStatusUpdate(String email, String message)
        }
