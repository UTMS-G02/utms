@startuml scenario-8-ygk-evaluation
autonumber
skinparam maxMessageSize 150
skinparam ParticipantPadding 20
skinparam BoxPadding 10

actor "Academic Staff (YGK)" as YGK

box "Presentation Layer" #LightCyan
    participant "EvaluationUI" as UI
    participant "EvaluationRestController" as RestController
end box

box "Business Logic Layer" #LightYellow
    participant "EvaluationService" as EvalService
    participant "RankingService" as RankingService
    participant "AuditService" as AuditSvc
end box

box "Data Access Layer" #LightGreen
    participant "TransferApplicationRepository" as AppRepo
    participant "EvaluationRepository" as EvalRepo
    participant "AuditLogRepository" as AuditDB
end box

box "Database" #LightPink
    participant "Database" as DB
end box

== 1. Application Loading & Auto-Scoring ==

YGK -> UI: selectApplication(applicationId)
activate UI

UI -> RestController: GET /api/evaluation/{id}/context
activate RestController

RestController -> EvalService: initializeEvaluation(applicationId)
activate EvalService

EvalService -> AppRepo: findById(applicationId)
activate AppRepo
AppRepo --> EvalService: ApplicationData (GPA, YKS)
deactivate AppRepo



EvalService -> EvalService: calculateCompositeScore()

EvalService --> RestController: EvaluationDTO (Score, Documents)
deactivate EvalService

RestController --> UI: Display Data (Score is\nGreyed Out/Locked)
deactivate RestController

UI --> YGK: Display Data (Score is\nGreyed Out/Locked)
deactivate UI

== 2. Qualitative Condition Check ==

YGK -> UI: checkDepartmentSpecificConditions()
activate UI

alt [Conditions Not Met]

    YGK -> UI: markShortcomings(notes)

    UI -> RestController: POST /api/evaluation/{id}/reject-conditions
    activate RestController

    RestController -> EvalService: recordConditionFailure(notes)
    activate EvalService

    EvalService -> AppRepo: updateStatus(id, "REJECTED_BY_YGK")
    activate AppRepo
    AppRepo --> EvalService: void
    deactivate AppRepo

    EvalService -> AuditSvc: logAction(staffId, applicationId,\n"Correction Requested")
    activate AuditSvc

    AuditSvc -> AuditDB: save(auditEntry)
    activate AuditDB

    AuditDB -> DB: persist(auditEntry)
    activate DB
    DB --> AuditDB: void
    deactivate DB

    AuditDB --> AuditSvc: void
    deactivate AuditDB

    AuditSvc --> EvalService: void
    deactivate AuditSvc

    EvalService --> RestController: void
    deactivate EvalService

    RestController --> UI: Application marked as unsuccessful
    deactivate RestController

    UI --> YGK: Application marked as unsuccessful
    deactivate UI

else [Conditions Met]

    YGK -> UI: confirmConditionsMet()
    activate UI

    UI -> RestController: POST /api/evaluation/{id}/confirm-conditions
    activate RestController

    RestController --> UI: 200 OK
    deactivate RestController

    deactivate UI

end

== 3. Finalization & Ranking ==

YGK -> UI: clickSubmitFinalEvaluation()
activate UI

UI -> RestController: POST /api/evaluation/{id}/finalize
activate RestController

RestController -> EvalService: finalizeEvaluation(id)
activate EvalService

EvalService -> EvalRepo: save(EvaluationReport)
activate EvalRepo
EvalRepo -> DB: INSERT INTO evaluations (...)
activate DB
DB --> EvalRepo: void
deactivate DB
EvalRepo --> EvalService: void
deactivate EvalRepo

== Score Handling ==

EvalService -> RankingService: updateRanking(score)
activate RankingService

RankingService -> AppRepo: findAppsWithScore(score)
activate AppRepo
AppRepo -> DB: SELECT * FROM apps\nWHERE score=? ORDER BY\napplication_date ASC
activate DB
DB --> AppRepo: SortedList
deactivate DB
AppRepo --> RankingService: SortedList
deactivate AppRepo

RankingService --> EvalService: void
deactivate RankingService

EvalService -> AuditSvc: logAction(ygkId, appId,\n"EVALUATION_COMPLETE")
activate AuditSvc

AuditSvc -> AuditDB: save(auditEntry)
activate AuditDB
AuditDB -> DB: persist(auditEntry)
activate DB
DB --> AuditDB: void
deactivate DB
AuditDB --> AuditSvc: void
deactivate AuditDB

AuditSvc --> EvalService: void
deactivate AuditSvc

EvalService -> AppRepo: updateStatus(id, "EVALUATED")
activate AppRepo
AppRepo --> EvalService: success
deactivate AppRepo

EvalService --> RestController: success
deactivate EvalService

RestController --> UI: HTTP 200 OK
deactivate RestController

UI --> YGK: Confirmation("Report forwarded\nto Dean's Office")
deactivate UI

@enduml